<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Uponthee — Find the perfect lodge around FUTO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/output.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <link rel="stylesheet" href="/src/navbar.css" />
  <link rel="stylesheet" href="/src/carousel.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #f8f6f3; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    .hero-1 { animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) forwards; }
    .hero-2 { animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s forwards; opacity:0; }
    .hero-3 { animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.2s forwards; opacity:0; }
    .search-bar { display:flex; width:100%; max-width:560px; border:1px solid rgba(0,0,0,0.08); border-radius:16px; background:white; box-shadow:0 4px 24px rgba(0,0,0,0.08); overflow:hidden; }
    .search-bar input { flex:1; padding:14px 18px; font-size:14px; border:none; outline:none; font-family:'DM Sans',sans-serif; color:#111827; background:transparent; }
    .search-bar input::placeholder { color:#9ca3af; }
    .search-bar button { padding:0 24px; background:#55142A; color:white; border:none; font-size:13px; font-weight:500; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background 0.2s; white-space:nowrap; }
    .search-bar button:hover { background:#6e1a35; }
    .trust-pill { display:inline-flex; align-items:center; gap:6px; background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.18); border-radius:999px; padding:5px 14px; font-size:12px; color:rgba(255,255,255,0.8); }
  </style>
</head>
<body class="min-h-screen pt-16">

  <%- include('partials/header.ejs') %>

  <main>

    <!-- Hero -->
    <section class="relative overflow-hidden bg-[#55142A] px-6 pb-22 pt-18 text-center">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_25%_60%,rgba(255,255,255,0.04)_0%,transparent_55%)]"></div>
      <div class="relative mx-auto max-w-2xl">
        <div class="hero-1 mb-6 flex flex-wrap justify-center gap-2.5">
          <span class="trust-pill">
            <svg class="h-3 w-3 fill-[#A79A79]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            1,200+ verified lodges
          </span>
          <span class="trust-pill">8,500+ students helped</span>
          <span class="trust-pill">FUTO-focused</span>
        </div>
        <h1 class="hero-2 mb-4 text-5xl font-medium leading-[1.15] text-white md:text-6xl" style="font-family:'Cormorant Garamond',serif;">
          Find the perfect lodge<br>
          <span class="text-[#A79A79]">around FUTO</span>
        </h1>
        <p class="hero-3 mx-auto mb-8 max-w-md text-[15px] leading-[1.75] text-white/60">
          Discover, compare and save the best student lodges near campus — verified listings, honest pricing, fast booking.
        </p>
        <div class="hero-3 flex justify-center">
          <form action="/search" method="get" class="search-bar w-full">
            <input type="text" name="q" placeholder="Search by location, name or price..." />
            <button type="submit">Search</button>
          </form>
        </div>
      </div>
    </section>

    <!-- Carousel -->
    <section class="mx-auto max-w-7xl px-5 pt-12">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <p class="mb-1 text-[11px] font-medium uppercase tracking-[0.15em] text-[#A79A79]">Trending now</p>
          <h2 class="text-2xl font-medium text-gray-900 md:text-3xl" style="font-family:'Cormorant Garamond',serif;">Popular lodges</h2>
        </div>
        <a href="/lodges" class="rounded-full border border-[#55142A]/20 px-4 py-1.5 text-[13px] text-[#55142A] transition hover:bg-[#55142A]/5">View all →</a>
      </div>
      <div class="overflow-hidden rounded-[20px]">
        <%- include('partials/carousel.ejs') %>
      </div>
    </section>

    <!-- Communities -->
    <section id="communities" class="mx-auto max-w-7xl px-5 pt-16">
      <div class="mb-10">
        <p class="mb-1 text-[11px] font-medium uppercase tracking-[0.15em] text-[#A79A79]">By location</p>
        <h2 class="text-2xl font-medium text-gray-900 md:text-3xl" style="font-family:'Cormorant Garamond',serif;">Explore by community</h2>
      </div>
      <%- include('partials/futo-communities.ejs') %>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-7xl px-5 pb-20 pt-16">
      <div class="rounded-3xl bg-[#55142A] px-10 py-14 text-center">
        <h2 class="mb-3 text-3xl font-medium text-white md:text-4xl" style="font-family:'Cormorant Garamond',serif;">Ready to find your next lodge?</h2>
        <p class="mx-auto mb-7 max-w-md text-sm text-white/60">Start exploring verified lodges and save your favourite places.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/lodges" class="inline-block rounded-xl bg-white px-7 py-3 text-sm font-medium text-[#55142A] transition hover:scale-[1.03]">Browse lodges</a>
          <% if (typeof user === 'undefined' || !user) { %>
          <a href="/sign-up" class="inline-block rounded-xl border border-white/20 bg-white/12 px-7 py-3 text-sm font-medium text-white transition hover:scale-[1.03]">Create account</a>
          <% } %>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer.ejs') %>

  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script src="/js/navbar.js"></script>
  <script src="/js/carousel.js"></script>
</body>
</html>
