<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/src/output.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />
    <link rel="stylesheet" href="/src/carousel.css">
    <title>Accomod</title>
  </head>
  <body class="px-8 pt-20">
    <!-- Header  -->
    <%- include('partials/header.ejs')%>

    <main>
      <!-- Trending Lodges carousel -->
      <%- include('partials/carousel.ejs') %>

      <!-- FUTO Communities -->
      <section>
        <!-- Umuchima Lodges -->
        <div>
          <h2 class="mb-4 text-2xl font-bold">Umuchima Lodges</h2>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <!-- Lodge Card -->
            <div class="overflow-hidden rounded-lg bg-white shadow-md">
              <img
                src="/images/lodge1.jpg"
                alt="Lodge 1"
                class="h-48 w-full object-cover"
              />
              <div class="p-4">
                <h3 class="text-lg font-semibold">Lodge Name</h3>
                <p class="text-gray-600">Location: Umuchima</p>
                <p class="text-gray-600">Price: $100/night</p>
              </div>
            </div>
            <!-- More lodge cards can be added here -->
          </div>
        </div>

        <!-- Eziobodo Lodges -->
        <div></div>
      </section>
    </main>

    <!-- Footer -->
    <%- include('partials/footer.ejs')%>
    <script src="/js/carousel.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  </body>
</html>
