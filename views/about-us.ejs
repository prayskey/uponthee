<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About Us</title>
    <link href="/src/output.css" rel="stylesheet" />
  </head>

  <body class="min-h-screen bg-[#f6f7fb] text-gray-900">
    <!-- HEADER -->
    <header
      class="fixed top-0 left-0 z-50 w-full border-b border-white/10 bg-[#55142A] backdrop-blur-md"
    >
      <div
        class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3"
      >
        <!-- Logo -->
        <div
          class="cursor-pointer text-2xl font-bold tracking-wide text-white transition hover:opacity-80"
        >
          Uponthee
        </div>

        <!-- Auth Buttons -->
        <div class="flex items-center gap-3">
          <!-- Login -->
          <a href="/sign-in">
            <button
              class="rounded-full px-5 py-1.5 cursor-pointer border-2 text-white/90 transition hover:bg-white hover:text-[#55142A] duration-300 hover:font-medium"
            >
              Login
            </button>
          </a>

          <!-- Sign Up (Primary CTA) -->
          <a href="/sign-up">
            <button
              class="rounded-full bg-white px-4 py-1.5 font-semibold cursor-pointer text-[#55142A] shadow-md transition duration-300 hover:scale-[1.03] hover:shadow-lg"
            >
              Get Started
            </button>
          </a>
        </div>
      </div>
    </header>

    <!-- MAIN CONTENT SECTION -->
    <main class="mx-auto max-w-6xl px-4 pt-24 pb-12 sm:px-6 lg:px-10">
      <!-- HERO -->
      <section class="mx-auto max-w-3xl text-center">
        <p class="text-xs tracking-widest text-gray-400 uppercase">About Us</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
          Building better lodge experiences for everyone
        </h1>
        <p class="mt-4 text-sm leading-relaxed text-gray-500 sm:text-base">
          We connect people to comfortable, affordable and trusted lodges across
          communities — making every stay simple, secure and memorable.
        </p>
      </section>

      <!-- STATS -->
      <section class="mt-14 grid grid-cols-2 gap-4 md:grid-cols-4">
        <div
          class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
        >
          <p class="text-2xl font-semibold">1,200+</p>
          <p class="mt-1 text-xs text-gray-400">Lodges Listed</p>
        </div>

        <div
          class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
        >
          <p class="text-2xl font-semibold">8,500+</p>
          <p class="mt-1 text-xs text-gray-400">Happy Users</p>
        </div>

        <div
          class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
        >
          <p class="text-2xl font-semibold">32+</p>
          <p class="mt-1 text-xs text-gray-400">Communities</p>
        </div>

        <div
          class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
        >
          <p class="text-2xl font-semibold">99%</p>
          <p class="mt-1 text-xs text-gray-400">Satisfaction</p>
        </div>
      </section>

      <!-- MISSION -->
      <section class="mt-16 grid items-center gap-10 md:grid-cols-2">
        <div>
          <h2 class="text-2xl font-semibold">Our Mission</h2>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            Our mission is to simplify accommodation discovery by removing
            stress, uncertainty, and inefficiency from booking lodges. We
            believe everyone deserves a seamless experience when finding a place
            to stay — whether short-term or long-term.
          </p>

          <div class="mt-6 space-y-3 text-sm text-gray-600">
            <p>✔ Trusted lodge listings</p>
            <p>✔ Transparent pricing</p>
            <p>✔ Fast booking experience</p>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-6">
          <div
            class="flex h-56 items-center justify-center rounded-xl bg-gray-100 text-gray-400"
          >
            Image / Illustration
          </div>
        </div>
      </section>

      <!-- VALUES -->
      <section class="mt-16">
        <h2 class="text-center text-2xl font-semibold">Our Values</h2>

        <div class="mt-8 grid gap-6 md:grid-cols-3">
          <div class="rounded-2xl border border-gray-100 bg-white p-6">
            <h3 class="font-medium">Trust</h3>
            <p class="mt-2 text-sm text-gray-500">
              We ensure every listing is verified and reliable.
            </p>
          </div>

          <div class="rounded-2xl border border-gray-100 bg-white p-6">
            <h3 class="font-medium">Simplicity</h3>
            <p class="mt-2 text-sm text-gray-500">
              Clean and fast booking experience with no confusion.
            </p>
          </div>

          <div class="rounded-2xl border border-gray-100 bg-white p-6">
            <h3 class="font-medium">Accessibility</h3>
            <p class="mt-2 text-sm text-gray-500">
              Everyone deserves easy access to accommodation.
            </p>
          </div>
        </div>
      </section>

      <!-- TEAM -->
      <section class="mt-16">
        <h2 class="text-center text-2xl font-semibold">Meet the Team</h2>

        <div class="mt-8 grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          <div
            class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
          >
            <div class="mx-auto h-16 w-16 rounded-full bg-gray-200"></div>
            <p class="mt-3 font-medium">Founder</p>
            <p class="text-xs text-gray-500">Product & Vision</p>
          </div>

          <div
            class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
          >
            <div class="mx-auto h-16 w-16 rounded-full bg-gray-200"></div>
            <p class="mt-3 font-medium">Developer</p>
            <p class="text-xs text-gray-500">Engineering</p>
          </div>

          <div
            class="rounded-2xl border border-gray-100 bg-white p-5 text-center"
          >
            <div class="mx-auto h-16 w-16 rounded-full bg-gray-200"></div>
            <p class="mt-3 font-medium">Support</p>
            <p class="text-xs text-gray-500">Customer Experience</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section
        class="mt-20 rounded-3xl bg-gray-900 p-10 text-center text-white"
      >
        <h2 class="text-2xl font-semibold">Start your journey with us</h2>
        <p class="mt-2 text-sm text-gray-300">
          Discover lodges that match your comfort and budget today.
        </p>

        <a
          href="/lodges"
          class="mt-6 inline-block rounded-xl bg-white px-6 py-2.5 text-sm font-medium text-gray-900 transition hover:bg-gray-200"
        >
          Explore Lodges
        </a>
      </section>
    </main>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
