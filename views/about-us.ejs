<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Uponthee</title>
  <link href="/src/output.css" rel="stylesheet" />
</head>

<body class="min-h-screen bg-gradient-to-b from-[#f6f7fb] to-white text-gray-900">

<!-- ================= HEADER ================= -->
<header class="fixed top-0 left-0 z-50 w-full bg-white/70 backdrop-blur-md border-b border-gray-100">
  <div class="mx-auto max-w-6xl flex items-center justify-between px-4 sm:px-6 h-16">

    <a href="/" class="text-xl font-semibold text-[#55142A] tracking-tight">
      Uponthee
    </a>

    <div class="flex items-center gap-3">
      <a href="/sign-in"
        class="text-sm text-gray-700 hover:text-[#55142A] transition">
        Login
      </a>

      <a href="/sign-up"
        class="text-sm px-4 py-2 rounded-full bg-[#55142A] text-white hover:scale-[1.03] transition">
        Get Started
      </a>
    </div>

  </div>
</header>

<!-- ================= MAIN ================= -->
<main class="pt-28 pb-16 px-4 sm:px-6">

  <!-- HERO -->
  <section class="text-center max-w-3xl mx-auto">
    <p class="text-xs tracking-[0.3em] text-gray-400 uppercase">
      About Uponthee
    </p>

    <h1 class="mt-4 text-4xl sm:text-5xl font-semibold leading-tight tracking-tight">
      Built for FUTO students finding better places to live
    </h1>

    <p class="mt-5 text-gray-600 text-sm sm:text-base leading-relaxed">
      Uponthee is a student-focused accommodation platform designed to simplify how students around FUTO discover, compare, and secure lodges.
      We remove uncertainty and replace it with clarity, trust, and speed.
    </p>
  </section>

  <!-- QUICK HIGHLIGHTS -->
  <section class="mt-14 grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">

    <div class="bg-white border rounded-2xl p-6 hover:shadow-sm transition">
      <h3 class="font-medium">Faster Discovery</h3>
      <p class="text-sm text-gray-500 mt-2">
        Find available lodges around your campus without stress or delay.
      </p>
    </div>

    <div class="bg-white border rounded-2xl p-6 hover:shadow-sm transition">
      <h3 class="font-medium">Verified Listings</h3>
      <p class="text-sm text-gray-500 mt-2">
        We focus on reliability so you don’t waste time on fake listings.
      </p>
    </div>

    <div class="bg-white border rounded-2xl p-6 hover:shadow-sm transition">
      <h3 class="font-medium">Student-Centered</h3>
      <p class="text-sm text-gray-500 mt-2">
        Built specifically for the FUTO community and surrounding areas.
      </p>
    </div>

  </section>

  <!-- STORY SECTION -->
  <section class="mt-20 max-w-5xl mx-auto grid md:grid-cols-2 gap-10 items-center">

    <div>
      <h2 class="text-2xl font-semibold">Why we built Uponthee</h2>

      <p class="mt-4 text-sm text-gray-600 leading-relaxed">
        Finding accommodation around FUTO has always been stressful — scattered information, unreliable contacts, and wasted time.
        We decided to fix that by building a system that organizes everything in one place.
      </p>

      <p class="mt-4 text-sm text-gray-600 leading-relaxed">
        Our goal is simple: help students make faster and safer housing decisions without confusion.
      </p>
    </div>

    <div class="bg-white border rounded-2xl p-6 shadow-sm">
      <div class="h-60 flex items-center justify-center bg-gray-100 rounded-xl text-gray-400">
        Image / Campus Illustration
      </div>
    </div>

  </section>

  <!-- STATS -->
  <section class="mt-20 max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 text-center">

    <div class="bg-white border rounded-2xl p-5">
      <p class="text-xl font-semibold">1,200+</p>
      <p class="text-xs text-gray-500 mt-1">Lodges</p>
    </div>

    <div class="bg-white border rounded-2xl p-5">
      <p class="text-xl font-semibold">8,500+</p>
      <p class="text-xs text-gray-500 mt-1">Users</p>
    </div>

    <div class="bg-white border rounded-2xl p-5">
      <p class="text-xl font-semibold">32+</p>
      <p class="text-xs text-gray-500 mt-1">Communities</p>
    </div>

    <div class="bg-white border rounded-2xl p-5">
      <p class="text-xl font-semibold">99%</p>
      <p class="text-xs text-gray-500 mt-1">Satisfaction</p>
    </div>

  </section>

  <!-- VALUES -->
  <section class="mt-20 text-center max-w-5xl mx-auto">

    <h2 class="text-2xl font-semibold">What we stand for</h2>

    <div class="mt-8 grid md:grid-cols-3 gap-6 text-left">

      <div class="bg-white border rounded-2xl p-6">
        <h3 class="font-medium">Trust</h3>
        <p class="text-sm text-gray-500 mt-2">
          Every listing is curated to reduce misinformation and risk.
        </p>
      </div>

      <div class="bg-white border rounded-2xl p-6">
        <h3 class="font-medium">Simplicity</h3>
        <p class="text-sm text-gray-500 mt-2">
          Clean flows, fewer steps, faster decisions.
        </p>
      </div>

      <div class="bg-white border rounded-2xl p-6">
        <h3 class="font-medium">Accessibility</h3>
        <p class="text-sm text-gray-500 mt-2">
          Built so every student can find accommodation easily.
        </p>
      </div>

    </div>

  </section>

  <!-- CTA -->
  <section class="mt-24 max-w-5xl mx-auto bg-[#55142A] text-white rounded-3xl p-10 text-center">

    <h2 class="text-2xl font-semibold">
      Start exploring lodges around FUTO
    </h2>

    <p class="mt-2 text-sm text-white/80">
      Join students already using Uponthee to find better accommodation.
    </p>

    <a href="/lodges"
      class="mt-6 inline-block bg-white text-[#55142A] px-6 py-2.5 rounded-xl text-sm font-medium hover:scale-[1.03] transition">
      Explore Lodges
    </a>

  </section>

</main>

</body>
</html>