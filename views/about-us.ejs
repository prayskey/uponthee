<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Uponthee</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link href="/src/output.css" rel="stylesheet" />
  <link rel="stylesheet" href="/src/navbar.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #f8f6f3; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { opacity: 0; }
    .fade-up.visible { animation: fadeUp 0.55s cubic-bezier(0.22,1,0.36,1) forwards; }
    .delay-1 { animation-delay: 80ms; }
    .delay-2 { animation-delay: 160ms; }
    .delay-3 { animation-delay: 240ms; }

    .stat-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 20px;
      padding: 24px;
      text-align: center;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(85,20,42,0.08);
    }

    .highlight-card {
      background: white;
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 20px;
      padding: 28px;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .highlight-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.07);
    }

    .icon-wrap {
      width: 44px; height: 44px;
      background: rgba(85,20,42,0.07);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 14px;
    }

    /* Counter animation */
    .count-up { display: inline-block; }
  </style>
</head>

<body class="min-h-screen pt-16">

  <%- include('partials/header.ejs') %>

  <!-- HERO -->
  <section style="background:#55142A; padding:80px 24px 100px; text-align:center; position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 30% 50%, rgba(255,255,255,0.04) 0%, transparent 60%); pointer-events:none;"></div>
    <div style="max-width:680px; margin:0 auto; position:relative;">
      <p style="font-size:11px; font-weight:500; letter-spacing:0.2em; color:rgba(167,154,121,0.9); text-transform:uppercase; margin-bottom:16px;" class="fade-up">About Uponthee</p>
      <h1 style="font-family:'Cormorant Garamond',serif; font-size:clamp(32px,5vw,52px); font-weight:500; color:white; line-height:1.2; margin-bottom:20px;" class="fade-up delay-1">
        Built for FUTO students finding better places to live
      </h1>
      <p style="font-size:15px; color:rgba(255,255,255,0.65); line-height:1.75; max-width:520px; margin:0 auto;" class="fade-up delay-2">
        Uponthee removes the stress from finding student accommodation around FUTO — replacing scattered information with clarity, trust, and speed.
      </p>
    </div>
  </section>

  <main style="max-width:1100px; margin:0 auto; padding:0 24px 80px;">

    <!-- STATS -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px; margin-top:-40px; margin-bottom:72px;" class="fade-up">
      <div class="stat-card">
        <p style="font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:500; color:#55142A;">
          <span class="count-up" data-target="1200">0</span>+
        </p>
        <p style="font-size:13px; color:#6b7280; margin-top:4px;">Lodges listed</p>
      </div>
      <div class="stat-card">
        <p style="font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:500; color:#55142A;">
          <span class="count-up" data-target="8500">0</span>+
        </p>
        <p style="font-size:13px; color:#6b7280; margin-top:4px;">Students helped</p>
      </div>
      <div class="stat-card">
        <p style="font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:500; color:#55142A;">
          <span class="count-up" data-target="32">0</span>+
        </p>
        <p style="font-size:13px; color:#6b7280; margin-top:4px;">Communities</p>
      </div>
      <div class="stat-card">
        <p style="font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:500; color:#55142A;">
          <span class="count-up" data-target="99">0</span>%
        </p>
        <p style="font-size:13px; color:#6b7280; margin-top:4px;">Satisfaction rate</p>
      </div>
    </div>

    <!-- HIGHLIGHTS -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; margin-bottom:80px;">
      <div class="highlight-card fade-up">
        <div class="icon-wrap">
          <svg style="width:20px;height:20px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
          </svg>
        </div>
        <h3 style="font-size:16px; font-weight:500; color:#111827; margin-bottom:8px;">Faster discovery</h3>
        <p style="font-size:13px; color:#6b7280; line-height:1.7;">Find available lodges around your campus without stress or delay. Browse by community, price, or amenities in seconds.</p>
      </div>
      <div class="highlight-card fade-up delay-1">
        <div class="icon-wrap">
          <svg style="width:20px;height:20px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
          </svg>
        </div>
        <h3 style="font-size:16px; font-weight:500; color:#111827; margin-bottom:8px;">Verified listings</h3>
        <p style="font-size:13px; color:#6b7280; line-height:1.7;">Every lodge is curated to reduce misinformation. You won't waste time on fake listings or unreliable contacts.</p>
      </div>
      <div class="highlight-card fade-up delay-2">
        <div class="icon-wrap">
          <svg style="width:20px;height:20px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
          </svg>
        </div>
        <h3 style="font-size:16px; font-weight:500; color:#111827; margin-bottom:8px;">Student-centered</h3>
        <p style="font-size:13px; color:#6b7280; line-height:1.7;">Built specifically for the FUTO community. Every feature is designed with student needs and budgets in mind.</p>
      </div>
    </div>

    <!-- STORY -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center; margin-bottom:80px;" class="story-grid fade-up">
      <div>
        <p style="font-size:11px; font-weight:500; letter-spacing:0.15em; color:#A79A79; text-transform:uppercase; margin-bottom:12px;">Our story</p>
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:32px; font-weight:500; color:#111827; line-height:1.3; margin-bottom:20px;">Why we built Uponthee</h2>
        <p style="font-size:14px; color:#4b5563; line-height:1.8; margin-bottom:16px;">
          Finding accommodation around FUTO has always been stressful — scattered information, unreliable contacts, and wasted time knocking on doors. Students deserved better.
        </p>
        <p style="font-size:14px; color:#4b5563; line-height:1.8;">
          We built Uponthee to fix that. One platform that organizes everything clearly: verified listings, real photos, honest pricing, and direct booking — all without the confusion.
        </p>
      </div>
      <div style="background:white; border:1px solid rgba(0,0,0,0.06); border-radius:20px; overflow:hidden; aspect-ratio:4/3; display:flex; align-items:center; justify-content:center;">
        <div style="text-align:center; padding:32px; color:#9ca3af;">
          <svg style="width:48px;height:48px;margin:0 auto 12px;opacity:0.3;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor"/>
            <circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor"/>
            <path stroke-linecap="round" d="m21 15-5-5L5 21"/>
          </svg>
          <p style="font-size:13px;">Campus illustration</p>
        </div>
      </div>
    </div>

    <!-- VALUES -->
    <div style="text-align:center; margin-bottom:32px;" class="fade-up">
      <p style="font-size:11px; font-weight:500; letter-spacing:0.15em; color:#A79A79; text-transform:uppercase; margin-bottom:12px;">What we stand for</p>
      <h2 style="font-family:'Cormorant Garamond',serif; font-size:32px; font-weight:500; color:#111827;">Our values</h2>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:20px; margin-bottom:80px;">
      <div class="highlight-card fade-up" style="border-left:3px solid #55142A; border-radius:0 20px 20px 0;">
        <h3 style="font-size:16px; font-weight:500; color:#111827; margin-bottom:8px;">Trust</h3>
        <p style="font-size:13px; color:#6b7280; line-height:1.7;">Every listing is curated to reduce misinformation and risk for students.</p>
      </div>
      <div class="highlight-card fade-up delay-1" style="border-left:3px solid #A79A79; border-radius:0 20px 20px 0;">
        <h3 style="font-size:16px; font-weight:500; color:#111827; margin-bottom:8px;">Simplicity</h3>
        <p style="font-size:13px; color:#6b7280; line-height:1.7;">Clean flows, fewer steps, faster decisions. No complexity for its own sake.</p>
      </div>
      <div class="highlight-card fade-up delay-2" style="border-left:3px solid #55142A; border-radius:0 20px 20px 0;">
        <h3 style="font-size:16px; font-weight:500; color:#111827; margin-bottom:8px;">Accessibility</h3>
        <p style="font-size:13px; color:#6b7280; line-height:1.7;">Built so every student — regardless of budget — can find good accommodation.</p>
      </div>
    </div>

    <!-- CTA -->
    <div style="background:#55142A; border-radius:24px; padding:56px 40px; text-align:center;" class="fade-up">
      <h2 style="font-family:'Cormorant Garamond',serif; font-size:32px; font-weight:500; color:white; margin-bottom:12px;">
        Start exploring lodges around FUTO
      </h2>
      <p style="font-size:14px; color:rgba(255,255,255,0.65); margin-bottom:28px; max-width:460px; margin-left:auto; margin-right:auto;">
        Join thousands of students already using Uponthee to find better, safer accommodation.
      </p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="/lodges" style="display:inline-block; background:white; color:#55142A; padding:12px 28px; border-radius:12px; font-size:14px; font-weight:500; text-decoration:none; transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
          Explore Lodges
        </a>
        <a href="/sign-up" style="display:inline-block; background:rgba(255,255,255,0.12); color:white; padding:12px 28px; border-radius:12px; font-size:14px; font-weight:500; text-decoration:none; border:1px solid rgba(255,255,255,0.2); transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
          Create account
        </a>
      </div>
    </div>

  </main>

  <%- include('partials/footer.ejs') %>

  <script src="/js/navbar.js"></script>
  <script>
    // Intersection observer for fade-up
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Responsive story grid
    const storyGrid = document.querySelector('.story-grid');
    if (window.innerWidth < 768 && storyGrid) storyGrid.style.gridTemplateColumns = '1fr';

    // Count-up animation
    function countUp(el) {
      const target = parseInt(el.dataset.target);
      const duration = 1200;
      const start = performance.now();
      function update(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target).toLocaleString();
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('.count-up').forEach(countUp);
          countObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('.stat-card').forEach(el => countObserver.observe(el.parentElement || el));
  </script>
</body>
</html>
