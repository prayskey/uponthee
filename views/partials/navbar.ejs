<!-- Desktop Nav -->
<nav class="hidden items-center space-x-6 font-medium md:flex">
  <ul class="flex space-x-6">
    <li>
      <a href="/home" class="text-sm text-white hover:text-gray-300">Home</a>
    </li>
    <li>
      <a href="/lodges" class="text-sm text-white hover:text-gray-300"
        >Lodges</a
      >
    </li>
    <li>
      <a href="/about-us" class="text-sm text-white hover:text-gray-300"
        >About Us</a
      >
    </li>
  </ul>

  <!-- Profile Dropdown -->
  <div class="relative">
    <button
      id="profile-toggle"
      class="flex cursor-pointer items-center gap-2 text-white focus:outline-none"
    >
      <!-- Avatar icon -->
      <div
        class="flex h-12 w-12 items-center justify-center rounded-full bg-white/20 transition hover:bg-white/30"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0zM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632z"
          />
        </svg>
      </div>
    </button>

    <!-- Dropdown Menu -->
    <div
      id="profile-dropdown"
      class="absolute right-0 z-50 mt-2 hidden w-48 overflow-hidden rounded-lg bg-white shadow-lg"
    >
      <a
        href="/profile"
        class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100"
        >My Profile</a
      >
      <a
        href="/bookings"
        class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100"
        >My Bookings</a
      >
      <a
        href="/saved"
        class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100"
        >Saved</a
      >
      <a
        href="/history"
        class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100"
        >History</a
      >
      <a
        href="/settings"
        class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100"
        >Settings</a
      >
      <div class="border-t border-gray-100"></div>
      <form action="/logout" method="post">
        <button
          type="submit"
          class="w-full cursor-pointer px-4 py-2.5 text-left text-sm text-red-600 hover:bg-gray-100"
        >
          Logout
        </button>
      </form>
    </div>
  </div>
</nav>

<!-- Mobile Hamburger only -->
<div class="flex items-center md:hidden">
  <button
    id="menu-toggle"
    class="text-white focus:outline-none"
    aria-label="Open menu"
  >
    <svg
      id="icon-open"
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M4 6h16M4 12h16M4 18h16"
      />
    </svg>
    <svg
      id="icon-close"
      xmlns="http://www.w3.org/2000/svg"
      class="hidden h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6 18L18 6M6 6l12 12"
      />
    </svg>
  </button>
</div>

<!-- Overlay -->
<div id="menu-overlay" class="fixed inset-0 z-40 bg-black/50"></div>

<!-- Slide-out Menu -->
<div
  id="mobile-menu"
  class="100dvh fixed top-0 left-0 z-50 flex w-64 flex-col bg-[#55142A] px-6 pt-6"
  style="height: 100dvh"
>
  <!-- Search inside mobile slide menu -->
  <div class="mb-8">
    <form action="/search" method="post">
      <input
        type="search"
        name="query"
        placeholder="Search for lodge"
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-white focus:border-[#A79A79] focus:outline-none"
      />
    </form>
  </div>

  <!-- Nav Links -->
  <nav>
    <ul class="flex flex-col space-y-6 text-sm">
      <li>
        <a href="/home" class="text-white hover:text-gray-300">Home</a>
      </li>
      <li>
        <a href="/lodges" class="text-white hover:text-gray-300">Lodges</a>
      </li>
      <li>
        <a href="/about-us" class="text-white hover:text-gray-300">About Us</a>
      </li>
    </ul>
  </nav>

  <!-- Profile Section at bottom -->
  <div
    class="mt-auto mb-8 flex flex-col space-y-4 border-t border-white/20 pt-6"
  >
    <a href="/profile" class="text-sm text-white hover:text-gray-300"
      >My Profile</a
    >
    <a href="/bookings" class="text-sm text-white hover:text-gray-300"
      >My Bookings</a
    >
    <a href="/saved" class="text-sm text-white hover:text-gray-300">Saved</a>
    <a href="/history" class="text-sm text-white hover:text-gray-300"
      >History</a
    >
    <a href="/settings" class="text-sm text-white hover:text-gray-300"
      >Settings</a
    >
    <form action="/logout" method="post">
      <button
        type="submit"
        class="text-sm text-red-400 hover:text-red-300 focus:outline-none"
      >
        Logout
      </button>
    </form>
  </div>

  <!-- Close button -->
  <button
    id="menu-close-btn"
    class="mb-4 text-left text-sm text-white/60 hover:text-white focus:outline-none"
  >
    ✕ Close menu
  </button>
</div>
