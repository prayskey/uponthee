<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saved Lodges</title>
    <link href="/src/output.css" rel="stylesheet" />
    <link rel="stylesheet" href="/src/navbar.css" />
  </head>

  <body
    class="flex min-h-screen flex-col bg-gradient-to-b from-gray-50 to-white"
  >
    <%- include('partials/header.ejs') %>

    <main class="mx-auto w-full max-w-7xl flex-1 px-4 pt-20 sm:px-6 lg:px-12">
      <!-- HEADER -->
      <div
        class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <h1 class="text-2xl font-semibold text-gray-900 sm:text-3xl">
            Saved Lodges
          </h1>
          <p class="mt-1 text-sm text-gray-500">
            Your wishlist of places you’re considering
          </p>
        </div>

        <!-- LIVE STATS -->
        <div class="flex gap-3 text-xs sm:text-sm">
          <div class="rounded-xl border bg-white px-3 py-2 shadow-sm">
            <p class="text-gray-400">Total</p>
            <p class="font-semibold text-gray-900" id="count">0</p>
          </div>

          <div class="rounded-xl border bg-white px-3 py-2 shadow-sm">
            <p class="text-gray-400">Affordable</p>
            <p class="font-semibold text-green-600" id="cheap">0</p>
          </div>

          <div class="rounded-xl border bg-white px-3 py-2 shadow-sm">
            <p class="text-gray-400">Premium</p>
            <p class="font-semibold text-gray-900" id="premium">0</p>
          </div>
        </div>
      </div>

      <!-- LIST -->
      <div
        id="saved-list"
        class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
      ></div>

      <!-- EMPTY STATE -->
      <div
        id="empty-state"
        class="animate-fade-in flex hidden flex-col items-center justify-center py-24 text-center"
      >
        <div class="mb-3 text-4xl">💭</div>

        <h3 class="text-lg font-semibold text-gray-800">
          Your wishlist is empty
        </h3>

        <p class="mx-auto mt-1 max-w-sm text-sm text-gray-500">
          Save lodges you like. Compare them later and decide when you're ready.
        </p>

        <button
          class="mt-6 rounded-xl bg-gray-900 px-6 py-2.5 text-sm text-white transition duration-300 hover:scale-[1.03] hover:bg-gray-800"
        >
          Explore lodges
        </button>
      </div>
    </main>

    <%- include('partials/footer.ejs') %>

    <script src="/js/saved-lodges.js"></script>
    <script src="/js/navbar.js"></script>
  </body>
</html>
