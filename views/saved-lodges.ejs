<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Saved Lodges — Uponthee</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link href="/src/output.css" rel="stylesheet" />
  <link rel="stylesheet" href="/src/navbar.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #f8f6f3; }
    @keyframes slideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    .lodge-card { opacity:0; animation:slideUp 0.45s cubic-bezier(0.22,1,0.36,1) forwards; transition:transform 0.2s ease,box-shadow 0.2s ease; }
    .lodge-card:hover { transform:translateY(-3px); box-shadow:0 8px 32px rgba(85,20,42,0.08); }
    .lodge-card .card-img { transition:transform 0.4s ease; }
    .lodge-card:hover .card-img { transform:scale(1.03); }
    .remove-btn { position:absolute; top:12px; right:12px; z-index:2; width:32px; height:32px; border-radius:50%; background:white; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px rgba(0,0,0,0.12); transition:background 0.15s,transform 0.15s; }
    .remove-btn:hover { background:#fee2e2; transform:scale(1.05); }
    .sort-btn { padding:6px 16px; border-radius:999px; font-size:13px; border:1px solid #e5e7eb; background:white; color:#6b7280; cursor:pointer; font-family:'DM Sans',sans-serif; transition:background 0.15s,color 0.15s,border-color 0.15s; }
    .sort-btn.active { background:#55142A; color:white; border-color:#55142A; }
  </style>
</head>
<body class="min-h-screen pt-16">

  <%- include('partials/header.ejs') %>

  <!-- Hero -->
  <div class="bg-[#55142A] px-6 pb-16 pt-12 md:px-12">
    <div class="mx-auto flex max-w-6xl flex-wrap items-end justify-between gap-5">
      <div>
        <p class="mb-2 text-[13px] tracking-[0.05em] text-[#A79A79]" style="font-family:'Cormorant Garamond',serif;">Your wishlist</p>
        <h1 class="text-4xl font-medium text-white md:text-5xl" style="font-family:'Cormorant Garamond',serif;">Saved lodges</h1>
        <p class="mt-2 text-[13px] text-white/50">Places you're considering for your next stay</p>
      </div>
      <div class="flex flex-wrap gap-2.5">
        <div class="min-w-[80px] rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-center">
          <p class="mb-1 text-[11px] text-white/50">Total</p>
          <p class="text-2xl font-medium text-white" style="font-family:'Cormorant Garamond',serif;" id="stat-total">0</p>
        </div>
        <div class="min-w-[80px] rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-center">
          <p class="mb-1 text-[11px] text-white/50">Affordable</p>
          <p class="text-2xl font-medium text-[#A79A79]" style="font-family:'Cormorant Garamond',serif;" id="stat-affordable">0</p>
        </div>
        <div class="min-w-[80px] rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-center">
          <p class="mb-1 text-[11px] text-white/50">Premium</p>
          <p class="text-2xl font-medium text-white" style="font-family:'Cormorant Garamond',serif;" id="stat-premium">0</p>
        </div>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-6xl px-6 pb-20 md:px-12">

    <!-- Sort -->
    <div class="mb-7 mt-8 flex flex-wrap gap-2" id="sort-wrap">
      <button class="sort-btn active" data-sort="saved">Recently saved</button>
      <button class="sort-btn" data-sort="price-asc">Price: low to high</button>
      <button class="sort-btn" data-sort="price-desc">Price: high to low</button>
    </div>

    <!-- Grid -->
    <div id="saved-list" class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>

    <!-- Empty -->
    <div id="empty-state" class="hidden py-20 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[#55142A]/[0.07]">
        <svg class="h-6 w-6 text-[#55142A]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
        </svg>
      </div>
      <p class="text-[22px] text-gray-700" style="font-family:'Cormorant Garamond',serif;">Your wishlist is empty</p>
      <p class="mx-auto mt-1 max-w-sm text-[13px] text-gray-400">Browse lodges and tap the heart icon to save ones you like. Compare them later when you're ready to decide.</p>
      <a href="/lodges" class="mt-6 inline-block rounded-xl bg-[#55142A] px-7 py-2.5 text-[13px] text-white transition hover:bg-[#6e1a35]">Explore lodges</a>
    </div>

  </main>

  <%- include('partials/footer.ejs') %>

  <script>
    const SAVED_DATA = <%- JSON.stringify(typeof savedLodges !== 'undefined' ? savedLodges : [
      { id:1, name:'Emerald Heights Lodge', location:'Port Harcourt, Rivers State', price:28000, rating:4.7, image:'/images/lodge1.jpg', savedAt: new Date().toISOString() },
      { id:2, name:'Riverside Guest House', location:'Asaba, Delta State',          price:18500, rating:4.3, image:'/images/lodge2.jpg', savedAt: new Date(Date.now()-86400000).toISOString() },
      { id:3, name:'Skyline Apartment',     location:'Lekki, Lagos',               price:45000, rating:4.8, image:'/images/lodge3.jpg', savedAt: new Date(Date.now()-172800000).toISOString() },
    ]) %>;
  </script>
  <script src="/js/navbar.js"></script>
  <script src="/js/saved-lodges.js"></script>
</body>
</html>
