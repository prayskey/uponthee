<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saved Lodges — Uponthee</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
      rel="stylesheet"
    />
    <link href="/src/output.css" rel="stylesheet" />
    <link rel="stylesheet" href="/src/navbar.css" />
    <style>
      body {
        font-family: "DM Sans", sans-serif;
        background: #f8f6f3;
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .lodge-card {
        background: white;
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 20px;
        overflow: hidden;
        opacity: 0;
        animation: slideUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }
      .lodge-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 32px rgba(85, 20, 42, 0.08);
      }

      .lodge-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
        background: #f1efe8;
        transition: transform 0.4s ease;
      }
      .lodge-card:hover .lodge-img {
        transform: scale(1.03);
      }

      .remove-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
        transition:
          background 0.15s,
          transform 0.15s;
      }
      .remove-btn:hover {
        background: #fee2e2;
        transform: scale(1.05);
      }

      .price-badge {
        position: absolute;
        bottom: 12px;
        left: 12px;
        z-index: 2;
        background: rgba(0, 0, 0, 0.6);
        color: white;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        backdrop-filter: blur(4px);
      }

      .sort-btn {
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 13px;
        border: 1px solid #e5e7eb;
        background: white;
        color: #6b7280;
        cursor: pointer;
        font-family: "DM Sans", sans-serif;
        transition:
          background 0.15s,
          color 0.15s,
          border-color 0.15s;
      }
      .sort-btn.active {
        background: #55142a;
        color: white;
        border-color: #55142a;
      }
    </style>
  </head>

  <body class="min-h-screen pt-16">
    <%- include('partials/header.ejs') %>

    <!-- Hero -->
    <div style="background: #55142a; padding: 48px 24px 64px">
      <div
        style="
          max-width: 1100px;
          margin: 0 auto;
          display: flex;
          align-items: flex-end;
          justify-content: space-between;
          flex-wrap: wrap;
          gap: 20px;
        "
      >
        <div>
          <p
            style="
              font-size: 13px;
              color: #a79a79;
              margin-bottom: 8px;
              font-family: &quot;Cormorant Garamond&quot;, serif;
              letter-spacing: 0.05em;
            "
          >
            Your wishlist
          </p>
          <h1
            style="
              font-family: &quot;Cormorant Garamond&quot;, serif;
              font-size: clamp(28px, 4vw, 42px);
              font-weight: 500;
              color: white;
            "
          >
            Saved lodges
          </h1>
          <p
            style="
              font-size: 13px;
              color: rgba(255, 255, 255, 0.5);
              margin-top: 6px;
            "
          >
            Places you're considering for your next stay
          </p>
        </div>
        <!-- Mini stats -->
        <div style="display: flex; gap: 10px; flex-wrap: wrap">
          <div
            style="
              background: rgba(255, 255, 255, 0.1);
              border: 1px solid rgba(255, 255, 255, 0.15);
              border-radius: 14px;
              padding: 12px 20px;
              min-width: 80px;
              text-align: center;
            "
          >
            <p
              style="
                font-size: 11px;
                color: rgba(255, 255, 255, 0.5);
                margin-bottom: 4px;
              "
            >
              Total
            </p>
            <p
              style="
                font-family: &quot;Cormorant Garamond&quot;, serif;
                font-size: 24px;
                font-weight: 500;
                color: white;
              "
              id="stat-total"
            >
              0
            </p>
          </div>
          <div
            style="
              background: rgba(255, 255, 255, 0.1);
              border: 1px solid rgba(255, 255, 255, 0.15);
              border-radius: 14px;
              padding: 12px 20px;
              min-width: 80px;
              text-align: center;
            "
          >
            <p
              style="
                font-size: 11px;
                color: rgba(255, 255, 255, 0.5);
                margin-bottom: 4px;
              "
            >
              Affordable
            </p>
            <p
              style="
                font-family: &quot;Cormorant Garamond&quot;, serif;
                font-size: 24px;
                font-weight: 500;
                color: #a79a79;
              "
              id="stat-affordable"
            >
              0
            </p>
          </div>
          <div
            style="
              background: rgba(255, 255, 255, 0.1);
              border: 1px solid rgba(255, 255, 255, 0.15);
              border-radius: 14px;
              padding: 12px 20px;
              min-width: 80px;
              text-align: center;
            "
          >
            <p
              style="
                font-size: 11px;
                color: rgba(255, 255, 255, 0.5);
                margin-bottom: 4px;
              "
            >
              Premium
            </p>
            <p
              style="
                font-family: &quot;Cormorant Garamond&quot;, serif;
                font-size: 24px;
                font-weight: 500;
                color: white;
              "
              id="stat-premium"
            >
              0
            </p>
          </div>
        </div>
      </div>
    </div>

    <main style="max-width: 1100px; margin: 0 auto; padding: 0 24px 80px">
      <!-- Sort -->
      <div
        style="
          display: flex;
          gap: 8px;
          flex-wrap: wrap;
          margin-top: 32px;
          margin-bottom: 28px;
        "
        id="sort-wrap"
      >
        <button class="sort-btn active" data-sort="saved">
          Recently saved
        </button>
        <button class="sort-btn" data-sort="price-asc">
          Price: low to high
        </button>
        <button class="sort-btn" data-sort="price-desc">
          Price: high to low
        </button>
      </div>

      <!-- Grid -->
      <div
        id="saved-list"
        style="
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
          gap: 20px;
        "
      ></div>

      <!-- Empty -->
      <div
        id="empty-state"
        style="display: none; text-align: center; padding: 80px 24px"
      >
        <div
          style="
            width: 56px;
            height: 56px;
            background: rgba(85, 20, 42, 0.07);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
          "
        >
          <svg
            style="width: 24px; height: 24px; color: #55142a; opacity: 0.4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
            />
          </svg>
        </div>
        <p
          style="
            font-family: &quot;Cormorant Garamond&quot;, serif;
            font-size: 22px;
            color: #374151;
            margin-bottom: 6px;
          "
        >
          Your wishlist is empty
        </p>
        <p
          style="
            font-size: 13px;
            color: #9ca3af;
            max-width: 360px;
            margin: 0 auto;
          "
        >
          Browse lodges and tap the heart icon to save ones you like. Compare
          them later when you're ready to decide.
        </p>
        <a
          href="/lodges"
          style="
            display: inline-block;
            margin-top: 24px;
            background: #55142a;
            color: white;
            padding: 11px 28px;
            border-radius: 12px;
            font-size: 13px;
            text-decoration: none;
            transition: background 0.2s;
          "
          onmouseover="this.style.background='#6e1a35'"
          onmouseout="this.style.background='#55142A'"
          >Explore lodges</a
        >
      </div>
    </main>

    <%- include('partials/footer.ejs') %>

    <script>
      const SAVED_DATA = <%- JSON.stringify(typeof savedLodges !== 'undefined' ? savedLodges : [
        { id:1, name:'Emerald Heights Lodge', location:'Port Harcourt, Rivers State', price:28000, rating:4.7, image:'/images/lodge1.jpg', savedAt: new Date().toISOString() },
        { id:2, name:'Riverside Guest House', location:'Asaba, Delta State',          price:18500, rating:4.3, image:'/images/lodge2.jpg', savedAt: new Date(Date.now()-86400000).toISOString() },
        { id:3, name:'Skyline Apartment',     location:'Lekki, Lagos',               price:45000, rating:4.8, image:'/images/lodge3.jpg', savedAt: new Date(Date.now()-172800000).toISOString() },
      ]) %>;
    </script>
    <script src="/js/navbar.js"></script>
    <script src="/js/saved-lodges.js"></script>
  </body>
</html>
