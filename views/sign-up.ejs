<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up - Uponthee</title>
    <link rel="stylesheet" href="/src/output.css" />
  </head>

  <body
    class="relative flex min-h-dvh items-center justify-center overflow-hidden bg-gradient-to-b from-[#f6f7fb] to-white px-4"
  >
    <!-- BACKGROUND DEPTH -->
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute top-[-180px] left-[-180px] h-[500px] w-[500px] rounded-full bg-[#55142A]/10 blur-3xl"
      ></div>
      <div
        class="absolute right-[-180px] bottom-[-200px] h-[500px] w-[500px] rounded-full bg-[#55142A]/10 blur-3xl"
      ></div>
    </div>

    <!-- CARD -->
    <main
      class="w-full max-w-md rounded-2xl border border-gray-100 bg-white p-8 shadow-xl sm:p-10"
    >
      <!-- HEADER -->
      <div class="text-center">
        <h1 class="text-3xl font-semibold tracking-tight text-gray-900">
          Create your account
        </h1>

        <p class="mt-2 text-sm text-gray-500">
          Join Uponthee and start exploring verified lodges around FUTO.
        </p>
      </div>

      <!-- SWITCH LINK -->
      <div class="mt-4 text-center text-sm text-gray-500">
        Already have an account?
        <a href="/sign-in" class="font-medium text-[#55142A] hover:underline">
          Sign in
        </a>
      </div>

      <!-- FORM -->
      <form action="/sign-up" method="post" class="mt-8 space-y-5">
        <!-- NAME GRID -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs text-gray-500">First name</label>
            <input
              type="text"
              name="firstName"
              placeholder="John"
              class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition focus:border-[#55142A] focus:ring-2 focus:ring-[#55142A]/20 focus:outline-none"
              required
            />
          </div>

          <div>
            <label class="text-xs text-gray-500">Last name</label>
            <input
              type="text"
              name="lastName"
              placeholder="Doe"
              class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition focus:border-[#55142A] focus:ring-2 focus:ring-[#55142A]/20 focus:outline-none"
              required
            />
          </div>
        </div>

        <!-- USERNAME -->
        <div>
          <label class="text-xs text-gray-500">Username</label>
          <input
            type="text"
            name="userName"
            placeholder="john_doe"
            class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition focus:border-[#55142A] focus:ring-2 focus:ring-[#55142A]/20 focus:outline-none"
            required
          />
        </div>

        <!-- EMAIL -->
        <div>
          <label class="text-xs text-gray-500">Email</label>
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition focus:border-[#55142A] focus:ring-2 focus:ring-[#55142A]/20 focus:outline-none"
            required
          />
        </div>

        <!-- PHONE -->
        <div>
          <label class="text-xs text-gray-500">Phone number</label>
          <input
            type="tel"
            name="phoneNumber"
            placeholder="+234..."
            class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition focus:border-[#55142A] focus:ring-2 focus:ring-[#55142A]/20 focus:outline-none"
            required
          />
        </div>

        <!-- PASSWORD -->
        <div>
          <label class="text-xs text-gray-500">Password</label>
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition focus:border-[#55142A] focus:ring-2 focus:ring-[#55142A]/20 focus:outline-none"
            required
          />
        </div>

        <!-- SUBMIT -->
        <button
          type="submit"
          class="w-full rounded-xl bg-[#55142A] py-3 font-medium text-white transition duration-200 hover:scale-[1.01] active:scale-[0.99]"
        >
          Create account
        </button>
      </form>
    </main>
  </body>
</html>
