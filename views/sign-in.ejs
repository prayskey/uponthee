<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/src/output.css" />
    <title>Uponthee</title>
  </head>
  <body class="flex min-h-dvh items-center justify-center bg-gray-100">
    <main class="my-auto bg-white px-6 py-10 rounded-lg shadow-md w-full max-w-sm ">
      <div class="space-y-4 mb-4">
        <h1 class="text-3xl font-bold text-center">Sign in</h1>
        <p>
          Don't have an account?
          <a href="/sign-up" class="text-blue-500 hover:underline"
            >Create your account</a
          >
        </p>
      </div>

      <form action="/sign-in" method="post">
        <fieldset class="flex flex-col space-y-4">
          <input
            type="text"
            class="rounded-sm border border-gray-500 px-2.5 py-2"
            placeholder="Email"
            name="email"
          />
          <input
            type="password"
            class="rounded-sm border border-gray-500 px-2.5 py-2"
            placeholder="Password"
            name="password"
          />
          <a href="/forgotten-password" class="text-right text-sm font-medium text-blue-500 hover:underline"
            >Forgotten password?</a
          >
          <button
            type="submit"
            class="transition-duration-300 cursor-pointer rounded bg-[#55142A] px-4 py-2 font-medium text-white transition hover:bg-[#55142A]/90"
          >
            Sign in
          </button>
        </fieldset>
      </form>
    </main>
  </body>
</html>
