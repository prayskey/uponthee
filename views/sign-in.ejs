<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign in - Uponthee</title>
  <link rel="stylesheet" href="/src/output.css" />
</head>

<body class="min-h-dvh flex items-center justify-center bg-gradient-to-b from-[#f6f7fb] to-white px-4 relative overflow-hidden">

  <!-- ================= BACKGROUND BLUR BLOBS ================= -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute w-[500px] h-[500px] bg-[#55142A]/10 blur-3xl rounded-full top-[-180px] left-[-180px]"></div>
    <div class="absolute w-[500px] h-[500px] bg-[#55142A]/10 blur-3xl rounded-full bottom-[-200px] right-[-180px]"></div>
  </div>

  <!-- ================= LOGIN CARD ================= -->
  <main class="w-full max-w-md bg-white border border-gray-100 shadow-xl rounded-2xl p-8 sm:p-10">

    <!-- HEADER -->
    <div class="text-center">
      <h1 class="text-3xl font-semibold tracking-tight text-gray-900">
        Welcome back
      </h1>

      <p class="mt-2 text-sm text-gray-500 leading-relaxed">
        Sign in to continue exploring verified lodges around FUTO.
      </p>
    </div>

    <!-- FORM -->
    <form action="/sign-in" method="post" class="mt-8 space-y-5">

      <!-- EMAIL -->
      <div>
        <label class="text-xs font-medium text-gray-500">Email</label>
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm
                 focus:outline-none focus:ring-2 focus:ring-[#55142A]/20 focus:border-[#55142A]
                 transition"
        />
      </div>

      <!-- PASSWORD -->
      <div>
        <label class="text-xs font-medium text-gray-500">Password</label>
        <input
          type="password"
          name="password"
          placeholder="••••••••"
          required
          class="mt-1 w-full rounded-xl border border-gray-200 px-4 py-3 text-sm
                 focus:outline-none focus:ring-2 focus:ring-[#55142A]/20 focus:border-[#55142A]
                 transition"
        />
      </div>

      <!-- FORGOT PASSWORD -->
      <div class="flex justify-end">
        <a href="/forgotten-password"
           class="text-xs text-[#55142A] hover:underline transition">
          Forgot password?
        </a>
      </div>

      <!-- SUBMIT BUTTON -->
      <button
        type="submit"
        class="w-full bg-[#55142A] text-white py-3 rounded-xl font-medium
               hover:scale-[1.01] active:scale-[0.99]
               transition duration-200"
      >
        Sign in
      </button>

    </form>

    <!-- FOOTER LINKS -->
    <div class="mt-6 text-center text-sm text-gray-500">
      Don’t have an account?
      <a href="/sign-up" class="text-[#55142A] font-medium hover:underline">
        Create account
      </a>
    </div>

  </main>

</body>
</html>